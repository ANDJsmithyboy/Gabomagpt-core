# ══════════════════════════════════════════════════════════
# GabomaGPT · Variables d'environnement
# SmartANDJ AI Technologies · Constitution Zion Core
# ══════════════════════════════════════════════════════════

# ── BRANDING COOLIFY (critique — supprime toute trace Open WebUI) ──
WEBUI_NAME=GabomaGPT
CUSTOM_NAME=GabomaGPT
WEBUI_AUTH=true
ENABLE_SIGNUP=true
DEFAULT_USER_ROLE=pending
WEBUI_FAVICON_URL=/static/favicon.png
WEBUI_SECRET_KEY=CHANGE_ME_RANDOM_SECRET_64CHARS
ENABLE_COMMUNITY_SHARING=false

# ── Ollama ──
OLLAMA_BASE_URL='http://localhost:11434'

# ── Modèles IA ──
GROQ_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
OPENAI_API_BASE_URL=''
OPENAI_API_KEY=''

# ── Base de données ──
POSTGRES_PASSWORD=gabomagpt_secret
DATABASE_URL=postgresql+asyncpg://gabomagpt:${POSTGRES_PASSWORD}@postgres/gabomagpt
REDIS_URL=redis://redis:6379
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Auth ──
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=

# ── Paiements ──
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=
AIRTEL_MONEY_ENV=sandbox
MOOV_SUMB_API_KEY=
INTERNAL_API_SECRET=gabomagpt_internal_2026
PAYMENT_RETURN_URL=https://gabomagpt.com/payment/confirm

# ── Application ──
PUBLIC_API_URL=https://gabomagpt.com
PUBLIC_APP_NAME=GabomaGPT
PUBLIC_COMPANY=SmartANDJ AI Technologies
PUBLIC_FOUNDER=Daniel Jonathan ANDJ
ENVIRONMENT=production

# ── Admin (invisible pour les utilisateurs) ──
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET

# ── Ports ──
GABOMAGPT_PORT=3000
GABOMAGPT_PUBLIC_PORT=80

# ── CORS ──
CORS_ALLOW_ORIGIN='*'
FORWARDED_ALLOW_IPS='*'

# ── Telemetry ──
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false