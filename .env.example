# ═══════════════════════════════════════════════════════════════
# GabomaGPT — Variables d'environnement · SmartANDJ AI Technologies
# Copier ce fichier vers .env et remplir les valeurs
# ═══════════════════════════════════════════════════════════════

# ── Base de données ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gabomagpt:gabomagpt_secret@localhost:5432/gabomagpt
POSTGRES_PASSWORD=gabomagpt_secret

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Groq (Flash + Pro) ───────────────────────────────────────
GROQ_API_KEY=gsk_votre_cle_groq_ici

# ── Anthropic (Black Panther mode) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-votre_cle_anthropic_ici

# ── Tavily (Web Search) ──────────────────────────────────────
TAVILY_API_KEY=tvly_votre_cle_tavily_ici

# ── Authentification JWT ──────────────────────────────────────
JWT_SECRET=changez_cette_valeur_en_production_gabomagpt_2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Airtel Money (Paiements XAF) ─────────────────────────────
AIRTEL_MONEY_API_KEY=
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_SECRET=

# ── Google OAuth 2.0 ───────────────────────────────────────────
# Console: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://gabomagpt.andjanalytics.com/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── OpenAI TTS (Voice) ─────────────────────────────────────────
OPENAI_TTS_API_KEY=sk-votre_cle_openai_tts_ici

# ── WebUI Secret (change in production!) ───────────────────────
WEBUI_SECRET_KEY=gabomagpt-secret-change-me-in-prod

# ── Environnement ────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
CORS_ORIGINS=https://gabomagpt.andjanalytics.com

# ── Application ──────────────────────────────────────────────
APP_NAME=GabomaGPT
APP_VERSION=1.0.0
COMPANY_NAME=SmartANDJ AI Technologies
FOUNDER=Daniel Jonathan ANDJ
