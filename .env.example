# ═══════════════════════════════════════════════════════════════
# GabomaGPT — Variables d'environnement · SmartANDJ AI Technologies
# Copier ce fichier vers .env et remplir les valeurs
# ═══════════════════════════════════════════════════════════════

# ── Base de données ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gabomagpt:gabomagpt_secret@localhost:5432/gabomagpt
POSTGRES_PASSWORD=gabomagpt_secret

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Groq (Flash + Pro) ───────────────────────────────────────
GROQ_API_KEY=gsk_votre_cle_groq_ici

# ── Kimi K2 (Black Panther) ──────────────────────────────────
KIMI_API_KEY=votre_cle_kimi_ici
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ── Tavily (Web Search) ──────────────────────────────────────
TAVILY_API_KEY=tvly_votre_cle_tavily_ici

# ── Authentification JWT ──────────────────────────────────────
JWT_SECRET=changez_cette_valeur_en_production_gabomagpt_2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Airtel Money (Paiements XAF) ─────────────────────────────
AIRTEL_MONEY_API_KEY=
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_SECRET=

# ── Environnement ────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Application ──────────────────────────────────────────────
APP_NAME=GabomaGPT
APP_VERSION=1.0.0
COMPANY_NAME=SmartANDJ AI Technologies
FOUNDER=Daniel Jonathan ANDJ
